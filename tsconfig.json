{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@creit-tech/stellar-wallets-kit/sdk": ["./src/__mocks__/@creit-tech/stellar-wallets-kit-sdk.ts"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "examples",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__",
    "src/**/*.test-d.ts"
  ]
}
